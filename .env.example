# Copy to `.env` for local development and fill in your Supabase project values.
# These VITE_ vars are embedded in the client bundle at build time — they are
# the PUBLIC Supabase URL and anon/publishable key (safe to expose), not secrets.
# In production, set these in your hosting platform's environment settings
# (e.g. Lovable / Vercel project env) rather than committing a real .env.

VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"
